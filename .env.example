# ============================================================
# TELEBOT AGENT MCP v2 — Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- CHANNELS (enable at least one) ----
ENABLE_TELEGRAM=true
ENABLE_WHATSAPP=false

# ---- TELEGRAM ----
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_OWNER_ID=123456789

# ---- WHATSAPP ----
# Phone number with country code, no +, no spaces (e.g. 6281234567890)
WHATSAPP_OWNER_NUMBER=6281234567890

# ---- AI PROVIDER ----
# Options: openai | openrouter | gemini | anthropic | groq | mistral | custom
AI_PROVIDER=openrouter

# ---- OPENAI ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- OPENROUTER ----
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.0-flash-exp

# ---- GEMINI ----
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash-exp

# ---- ANTHROPIC ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---- GROQ ----
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ---- CUSTOM PROVIDER (OpenAI-compatible) ----
# Supports any provider with OpenAI-compatible API
CUSTOM_API_KEY=your_api_key
CUSTOM_BASE_URL=https://your-provider.com/v1
CUSTOM_MODEL=your-model-name

# ---- AGENT SETTINGS ----
AGENT_NAME=Cupang
AGENT_SYSTEM_PROMPT=You are a powerful AI agent. You can execute commands, read/write files, search the web, make HTTP requests, and help with any task. Be concise, helpful, and proactive.
MAX_TOKENS=4096
TEMPERATURE=0.7
MAX_HISTORY=20

# ---- APPROVAL SYSTEM ----
# If true, new users need owner approval before using the bot
REQUIRE_APPROVAL=true

# ---- TOOLS / MCP ----
# Enable/disable specific tool categories
TOOL_SHELL=true
TOOL_FILE=true
TOOL_WEB=true
TOOL_HTTP=true
TOOL_CODE=true

# ---- DATABASE ----
DB_PATH=./data/agent.db

# ---- HTTP SERVER (for health checks in Pterodactyl) ----
HTTP_PORT=3000
HTTP_ENABLED=true

# ---- LOGGING ----
LOG_LEVEL=info
